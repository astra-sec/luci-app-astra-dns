config main 'main'
	option enabled '0'
	option redirect 'none'
	option configpath '/etc/astra-dns/named.yaml'
	option workdir '/var/lib/astra-dns'
	option logfile '/tmp/astra-dns.log'
	option verbose '0'
	option binpath '/usr/bin/astra-dns'
	option target ''
	option downloadlinks 'https://github.com/astra-sec/astra-dns/releases/latest/download/astra-dns-${Target}.tar.gz'
